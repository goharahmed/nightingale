{
  "name": "Nightingale",
  "version": "0.5.0",
  "private": true,
  "description": "Nightingale — Karaoke from your music library.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons": "tauri icon src/assets/images/logo_square.png",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "format:staged": "oxfmt --no-error-on-unmatched-pattern",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "cd .. && husky client/.husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^4.43.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "jotai": "^2.18.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "pitchy": "^4.1.0",
    "pretty-bytes": "^7.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.13.1",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "~5.8.3",
    "vite": "^8.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint",
    "*": "pnpm run format:staged"
  }
}
