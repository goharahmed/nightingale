---
const highlights = [
  {
    title: "Key and tempo controls",
    description: "Adjust analyzed songs to better match your voice without leaving the library view.",
  },
  {
    title: "Setup with data-folder choice",
    description:
      "Pick where Nightingale stores cache, models, and vendor tools during first-run setup.",
  },
  {
    title: "Faster library flow",
    description:
      "Use sidebar filters and Analyze All to quickly find songs and queue batch analysis.",
  },
  {
    title: "Playback upgrades",
    description:
      "Use mic mirroring and more robust source-video playback for smoother practice sessions.",
  },
];
---

<section id="highlights">
  <div class="container">
    <div class="header">
      <h2>What&apos;s new in v0.5</h2>
      <a href="/docs/" class="docs-link">See full docs</a>
    </div>
    <div class="highlights-grid">
      {
        highlights.map((item) => (
          <article class="highlight-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 20px;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
  }

  .docs-link {
    font-size: 0.9rem;
    color: var(--accent);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .highlight-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.04);
    padding: 18px;
  }

  .highlight-card h3 {
    margin: 0 0 6px;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .highlight-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .highlights-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
